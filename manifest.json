{
  "name": "RawFlip Marketplace",
  "short_name": "RawFlip",
  "description": "Buy and sell anything — new and used items, great deals or quick flips.",
  "start_url": "/",
  "display": "standalone",
  "display_override": ["standalone", "minimal-ui", "browser"],
  "background_color": "#0a0a0f",
  "theme_color": "#ff4e1f",
  "dir": "ltr",
  "lang": "en",
  "orientation": "portrait",
  "id": "com.rawflip.marketplace",
  "scope": "/",
  "categories": ["shopping", "finance"],
  "iarc_rating_id": "",
  "icons": [
    { "src": "/icons/icon-64.png",           "sizes": "64x64",   "type": "image/png", "purpose": "any" },
    { "src": "/icons/icon-128.png",          "sizes": "128x128", "type": "image/png", "purpose": "any" },
    { "src": "/icons/icon-192.png",          "sizes": "192x192", "type": "image/png", "purpose": "any" },
    { "src": "/icons/icon-256.png",          "sizes": "256x256", "type": "image/png", "purpose": "any" },
    { "src": "/icons/icon-512.png",          "sizes": "512x512", "type": "image/png", "purpose": "any" },
    { "src": "/icons/icon-maskable-192.png", "sizes": "192x192", "type": "image/png", "purpose": "maskable" },
    { "src": "/icons/icon-maskable-512.png", "sizes": "512x512", "type": "image/png", "purpose": "maskable" }
  ],
  "screenshots": [
    {
      "src": "/screenshots/home.png",
      "sizes": "720x1600",
      "type": "image/png",
      "form_factor": "narrow",
      "label": "Home — browse live listings"
    },
    {
      "src": "/screenshots/listing.png",
      "sizes": "720x1600",
      "type": "image/png",
      "form_factor": "narrow",
      "label": "Listing detail with secure escrow"
    },
    {
      "src": "/screenshots/wallet.png",
      "sizes": "720x1600",
      "type": "image/png",
      "form_factor": "narrow",
      "label": "Wallet — deposit, withdraw and track"
    }
  ],
  "share_target": {
    "action": "/share",
    "method": "GET",
    "enctype": "application/x-www-form-urlencoded",
    "params": {
      "title": "title",
      "text": "text",
      "url": "url"
    }
  },
  "protocol_handlers": [
    {
      "protocol": "web+rawflip",
      "url": "/?action=%s"
    }
  ],
  "launch_handler": {
    "client_mode": "focus-existing"
  },
  "scope_extensions": [
    { "origin": "https://rawflip.shop" }
  ],
  "shortcuts": [
    {
      "name": "New Listing",
      "short_name": "Sell",
      "description": "Create a new listing instantly",
      "url": "/?action=sell",
      "icons": [
        { "src": "/icons/icon-192.png", "sizes": "192x192", "type": "image/png" }
      ]
    },
    {
      "name": "My Wallet",
      "short_name": "Wallet",
      "description": "Check your balance and transactions",
      "url": "/?action=wallet",
      "icons": [
        { "src": "/icons/icon-192.png", "sizes": "192x192", "type": "image/png" }
      ]
    },
    {
      "name": "Notifications",
      "short_name": "Alerts",
      "description": "View your latest notifications",
      "url": "/?action=notifications",
      "icons": [
        { "src": "/icons/icon-192.png", "sizes": "192x192", "type": "image/png" }
      ]
    }
  ],
  "prefer_related_applications": false,
  "related_applications": []
}
