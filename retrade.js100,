// Improved rate limiter factory with better error responses
const createRateLimiter = (options) => {
    return rateLimit({
        windowMs: options.windowMs || 15 * 60 * 1000,
        max: options.max || 100,
        standardHeaders: true,
        legacyHeaders: false,
        keyGenerator: options.keyGenerator || ((req) => {
            return req.user ? req.user._id.toString() : req.ip;
        }),
        skipSuccessfulRequests: options.skipSuccessfulRequests || false,
        skip: options.skip || (() => false),
        handler: (req, res) => {
            const retryAfter = Math.ceil(options.windowMs / 1000);
            const limit = options.max;
            
            res.setHeader('Retry-After', retryAfter);
            res.setHeader('X-RateLimit-Limit', limit);
            res.setHeader('X-RateLimit-Remaining', 0);
            res.setHeader('X-RateLimit-Reset', Math.ceil((Date.now() + options.windowMs) / 1000));
            
            console.warn(`⚠️ Rate limit exceeded for ${req.ip} on ${req.method} ${req.url}`);
            
            // Provide more specific error message based on endpoint type
            let message = 'Too many requests. Please try again later.';
            if (options.windowMs === 60 * 60 * 1000) {
                message = 'Too many authentication attempts. Please try again in an hour.';
            } else if (options.windowMs === 15 * 60 * 1000 && options.max === 300) {
                message = 'API rate limit reached. Please slow down your requests.';
            }
            
            res.status(429).json({
                success: false,
                message,
                retryAfter,
                limit,
                reset: new Date(Date.now() + options.windowMs).toISOString(),
                code: 'RATE_LIMIT_EXCEEDED'
            });
        }
    });
};

