app.post('/api/login', 
    (req, res, next) => {
        req.validationRules = ['username', 'password'];
        next();
    },
    body('username').notEmpty().withMessage('Username required'),
    body('password').notEmpty().withMessage('Password required'),
    validate,
    async (req, res) => {
        try {
            const { username, password, twoFACode, device } = req.body;

            const user = await User.findOne({
                $or: [{ username }, { email: username }]
            });

            if (!user) {
                await trackEvent(null, 'login_failed', 'user', 'authentication', null, { reason: 'user_not_found' }, req);
                return res.status(400).json({ 
                    success: false, 
                    message: 'Invalid credentials',
                    code: 'INVALID_CREDENTIALS'
                });
            }

            const validPassword = await bcrypt.compare(password, user.password);
            if (!validPassword) {
                await trackEvent(user._id, 'login_failed', 'user', 'authentication', null, { reason: 'invalid_password' }, req);
                return res.status(400).json({ 
                    success: false, 
                    message: 'Invalid credentials',
                    code: 'INVALID_CREDENTIALS'
                });
            }

            if (user.twoFA_enabled) {
                if (!twoFACode) {
                    return res.json({
                        success: true,
                        requires2FA: true,
                        message: '2FA code required',
                        code: '2FA_REQUIRED'
                    });
                }

                const verified = speakeasy.totp.verify({
                    secret: user.twoFA_secret,
                    encoding: 'base32',
                    token: twoFACode,
                    window: 1
                });

                if (!verified) {
                    const backupCode = user.twoFA_backup_codes.find(code => 
                        !code.used && code.code === twoFACode
                    );
                    
                    if (!backupCode) {
                        await trackEvent(user._id, 'login_failed', 'user', 'authentication', null, { reason: 'invalid_2fa' }, req);
                        return res.status(400).json({ 
                            success: false, 
                            message: 'Invalid 2FA code',
                            code: 'INVALID_2FA'
                        });
                    }
                    
                    backupCode.used = true;
                    await user.save();
                }
            }

            const token = jwt.sign(
                { userId: user._id, username: user.username, role: user.role },
                process.env.JWT_SECRET,
                { expiresIn: '15m' }
            );

            const refreshToken = generateRefreshToken();
            const session = new Session({
                userId: user._id,
                token,
                refreshToken,
                expiresAt: new Date(Date.now() + CONSTANTS.SESSION_EXPIRY_DAYS * 24 * 60 * 60 * 1000),
                device,
                ip: req.ip
            });
            await session.save();

            user.loginHistory.push({ device, ip: req.ip, timestamp: new Date() });
            user.lastLogin = new Date();
            await user.save();

            await auditLog(user._id, 'login', 'User', user._id, { 
                success: true, 
                method: user.twoFA_enabled ? '2fa' : 'password' 
            }, req);

            await trackEvent(user._id, 'login', 'user', 'authentication', null, { method: user.twoFA_enabled ? '2fa' : 'password' }, req);

            // Return minimal user data initially, full data can be fetched separately
            res.json({
                success: true,
                data: {
                    token,
                    refreshToken,
                    expiresIn: 900,
                    user: {
                        _id: user._id,
                        username: user.username,
                        email: user.email,
                        region: user.region,
                        accountType: user.accountType,
                        balance: user.balance,
                        earningBalance: user.earningBalance,
                        locked: user.locked,
                        trustScore: user.trustScore,
                        plan: user.plan,
                        kyc_status: user.kyc_status,
                        role: user.role,
                        address: user.address,
                        withdraw_method: user.withdraw_method,
                        watchlist: user.watchlist || []
                    }
                }
            });

        } catch (error) {
            console.error('Login error:', error);
            res.status(500).json({ 
                success: false, 
                message: 'Login failed',
                code: 'LOGIN_FAILED'
            });
        }
    }
);

