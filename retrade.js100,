app.post('/api/user/update', 
    authenticate,
    (req, res, next) => {
        const rules = [];
        if (req.body.email) rules.push('email');
        if (req.body.password) rules.push('password');
        req.validationRules = rules;
        next();
    },
    body('email').optional().isEmail().normalizeEmail().withMessage('Valid email required'),
    body('password').optional().isLength({ min: 8 }).matches(/^(?=.*[a-z])(?=.*[A-Z])(?=.*\d)/).withMessage('Password must contain at least one uppercase letter, one lowercase letter, and one number'),
    validate,
    async (req, res) => {
        try {
            const { email, address, withdraw_method, password } = req.body;
            const user = await User.findById(req.user._id);
            const changes = [];

            if (email && email !== user.email) {
                const existingUser = await User.findOne({ email }).lean();
                if (existingUser && existingUser._id.toString() !== user._id.toString()) {
                    return res.status(400).json({ 
                        success: false, 
                        message: 'Email already in use',
                        field: 'email',
                        code: 'DUPLICATE_EMAIL'
                    });
                }
                user.email = email;
                changes.push('email');
            }
            if (address !== undefined) {
                user.address = address;
                changes.push('address');
            }
            if (withdraw_method !== undefined) {
                user.withdraw_method = withdraw_method;
                changes.push('withdraw_method');
            }
            if (password) {
                user.password = await bcrypt.hash(password, 12);
                changes.push('password');
                
                // Invalidate other sessions on password change
                await Session.deleteMany({ userId: user._id, _id: { $ne: req.session._id } });
                
                await auditLog(user._id, 'password_change', 'User', user._id, null, req);
            }

            user.updatedAt = new Date();
            await user.save();

            if (changes.length > 0 && !changes.includes('password')) {
                await auditLog(user._id, 'profile_update', 'User', user._id, { changes }, req);
            }

            await trackEvent(user._id, 'profile_update', 'user', 'settings', null, { changes }, req);

            res.json({ success: true, message: 'Profile updated successfully' });

        } catch (error) {
            console.error('Update profile error:', error);
            res.status(500).json({ 
                success: false, 
                message: 'Failed to update profile',
                code: 'UPDATE_FAILED'
            });
        }
    }
);

