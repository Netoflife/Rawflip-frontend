// Subscribe to plan
app.post('/api/user/subscribe', 
    authenticate,
    (req, res, next) => {
        req.validationRules = ['plan'];
        next();
    },
    body('plan').isIn(['basic', 'pro']).withMessage('Invalid plan'),
    validate,
    async (req, res) => {
        try {
            const { plan } = req.body;
            
            if (!['basic', 'pro'].includes(plan)) {
                return res.status(400).json({ 
                    success: false, 
                    message: 'Invalid plan',
                    code: 'INVALID_PLAN'
                });
            }

            const price = CONSTANTS.SUBSCRIPTION_PRICES[plan];
            const user = await User.findById(req.user._id);

            const totalFunds = user.balance + user.earningBalance;
            if (totalFunds < price) {
                return res.status(400).json({ 
                    success: false, 
                    message: `Insufficient funds. Need ₦${price}, have ₦${totalFunds}`,
                    required: price,
                    available: totalFunds,
                    code: 'INSUFFICIENT_FUNDS'
                });
            }

            let amountToDeduct = price;
            
            if (user.balance >= amountToDeduct) {
                user.balance -= amountToDeduct;
            } else {
                const fromBalance = user.balance;
                amountToDeduct -= fromBalance;
                user.balance = 0;
                user.earningBalance -= amountToDeduct;
            }

            user.plan = plan;
            await user.save();

            const transaction = new Transaction({
                userId: user._id,
                type: 'fee',
                amount: price,
                description: `${plan.toUpperCase()} subscription`,
                status: 'completed',
                reference: generateReference()
            });

            await transaction.save();

            await auditLog(user._id, 'subscription', 'User', user._id, { 
                plan, 
                price 
            }, req);

            await trackEvent(user._id, 'subscribe', 'subscription', 'purchase', price, { 
                plan 
            }, req);

            res.json({
                success: true,
                message: `Successfully subscribed to ${plan} plan`,
                data: { plan, price }
            });

        } catch (error) {
            console.error('Subscribe error:', error);
            res.status(500).json({ 
                success: false, 
                message: 'Failed to subscribe',
                code: 'SUBSCRIPTION_FAILED'
            });
        }
    }
);

