// Track active connections per user
const activeConnections = new Map();

io.on('connection', (socket) => {
    console.log('🔌 New socket connection:', socket.id, 'User:', socket.username);
    
    // Track connection
    if (!activeConnections.has(socket.userId)) {
        activeConnections.set(socket.userId, new Set());
    }
    activeConnections.get(socket.userId).add(socket.id);

    socket.on('presence', (data) => {
        socket.data.status = data.status;
        socket.data.listingId = data.listingId;
        
        if (data.listingId) {
            socket.join(`listing_${data.listingId}`);
        }
    });

    socket.on('check_peer', async (data) => {
        try {
            const { listingId } = data;
            const sockets = await io.fetchSockets();
            const peerSocket = sockets.find(s => 
                s.data.listingId === listingId && s.id !== socket.id
            );
            
            socket.emit('peer_status', {
                listingId,
                online: !!peerSocket
            });
        } catch (error) {
            console.error('❌ Check peer error:', error);
        }
    });

    socket.on('join_conversation', (data) => {
        if (data.conversationId) {
            socket.join(data.conversationId);
        }
    });

    socket.on('leave_conversation', (data) => {
        if (data.conversationId) {
            socket.leave(data.conversationId);
        }
    });

    socket.on('typing', (data) => {
        socket.to(`listing_${data.listingId}`).emit('typing', {
            userId: socket.userId,
            username: socket.username,
            listingId: data.listingId
        });
    });

    socket.on('disconnect', () => {
        console.log('🔌 Socket disconnected:', socket.id);
        
        // Remove connection tracking
        if (activeConnections.has(socket.userId)) {
            const connections = activeConnections.get(socket.userId);
            connections.delete(socket.id);
            if (connections.size === 0) {
                activeConnections.delete(socket.userId);
            }
        }
    });
});

