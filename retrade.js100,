// Buy listing
app.post('/api/buy/:listingId', 
    authenticate,
    (req, res, next) => {
        req.validationRules = ['listingId', 'address'];
        next();
    },
    param('listingId').isMongoId().withMessage('Invalid listing ID'),
    body('address').notEmpty().withMessage('Delivery address required'),
    body('offerId').optional().isMongoId().withMessage('Invalid offer ID'),
    validate,
    async (req, res) => {
        try {
            const { address, offerId } = req.body;
            const listing = await Listing.findById(req.params.listingId).populate('seller');
            let offer = null;
            let price = listing?.price;

            if (!listing) {
                return res.status(404).json({ 
                    success: false, 
                    message: 'Listing not found',
                    code: 'LISTING_NOT_FOUND'
                });
            }

            if (offerId) {
                offer = await Offer.findById(offerId);
                
                if (!offer) {
                    return res.status(404).json({ 
                        success: false, 
                        message: 'Offer not found',
                        code: 'OFFER_NOT_FOUND'
                    });
                }
                
                if (offer.listingId.toString() !== listing._id.toString()) {
                    return res.status(400).json({ 
                        success: false, 
                        message: 'Offer does not match this listing',
                        code: 'OFFER_MISMATCH'
                    });
                }
                
                if (offer.buyerId.toString() !== req.user._id.toString()) {
                    return res.status(403).json({ 
                        success: false, 
                        message: 'Offer does not belong to you',
                        code: 'OFFER_NOT_YOURS'
                    });
                }
                
                if (offer.status !== 'accepted') {
                    return res.status(400).json({ 
                        success: false, 
                        message: 'Offer is not accepted',
                        code: 'OFFER_NOT_ACCEPTED'
                    });
                }
                
                if (offer.used) {
                    return res.status(400).json({ 
                        success: false, 
                        message: 'Offer has already been used',
                        code: 'OFFER_USED'
                    });
                }
                
                if (offer.expiresAt < new Date()) {
                    return res.status(400).json({ 
                        success: false, 
                        message: 'Offer has expired',
                        code: 'OFFER_EXPIRED'
                    });
                }
                
                price = offer.acceptedPrice;
            }

            if (listing.seller._id.toString() === req.user._id.toString()) {
                return res.status(400).json({ 
                    success: false, 
                    message: 'Cannot buy your own listing',
                    code: 'SELF_PURCHASE'
                });
            }

            if (listing.status !== 'active') {
                return res.status(400).json({ 
                    success: false, 
                    message: 'Listing is not available for purchase',
                    code: 'LISTING_NOT_AVAILABLE'
                });
            }

            const existingOrder = await Order.findOne({ 
                listingId: listing._id,
                status: { $in: ['escrow_locked', 'dispatched', 'delivered'] }
            });
            if (existingOrder) {
                return res.status(400).json({ 
                    success: false, 
                    message: 'Active order already exists for this listing',
                    code: 'ORDER_EXISTS'
                });
            }

            const fee = price * CONSTANTS.ESCROW_FEE_RATE;
            const total = price + fee;

            const buyer = await User.findById(req.user._id);
            if (buyer.balance < total) {
                return res.status(400).json({ 
                    success: false, 
                    message: `Insufficient balance. Need ₦${total.toFixed(2)}, have ₦${buyer.balance.toFixed(2)}`,
                    required: total,
                    available: buyer.balance,
                    code: 'INSUFFICIENT_BALANCE'
                });
            }

            const session = await mongoose.startSession();
            session.startTransaction();

            try {
                buyer.balance -= total;
                buyer.locked += total;
                await buyer.save({ session });

                listing.status = 'escrow';
                await listing.save({ session });

                if (offer) {
                    offer.used = true;
                    offer.status = 'used';
                    await offer.save({ session });
                }

                const order = new Order({
                    listingId: listing._id,
                    buyerId: buyer._id,
                    sellerId: listing.seller._id,
                    title: listing.title,
                    buyer: buyer.username,
                    seller: listing.seller.username,
                    price,
                    fee,
                    total,
                    status: 'escrow_locked',
                    address,
                    offerId: offer ? offer._id : null
                });

                await order.save({ session });

                const transaction = new Transaction({
                    userId: buyer._id,
                    type: 'purchase',
                    amount: total,
                    description: offer ? `Purchase with offer: ${listing.title}` : `Purchase: ${listing.title}`,
                    status: 'escrow_locked',
                    reference: generateReference(),
                    metadata: { orderId: order._id, listingId: listing._id, offerId: offer?._id }
                });

                await transaction.save({ session });

                const notification = new Notification({
                    userId: listing.seller._id,
                    type: 'transaction',
                    message: `Your item "${listing.title}" has been purchased by ${buyer.username}`,
                    data: { orderId: order._id, listingId: listing._id, offerId: offer?._id }
                });

                await notification.save({ session });

                await auditLog(buyer._id, 'purchase', 'Order', order._id, { 
                    listing: listing.title, 
                    price: total,
                    offerId: offer?._id
                }, req);

                await trackEvent(buyer._id, 'purchase', 'transaction', 'create', total, { 
                    orderId: order._id,
                    listingId: listing._id,
                    sellerId: listing.seller._id,
                    offerId: offer?._id
                }, req);

                await session.commitTransaction();

                // Emit socket events
                io.to(`user_${listing.seller._id}`).emit('notification', {
                    userId: listing.seller._id.toString(),
                    message: `Your item "${listing.title}" has been purchased. Order #${order._id.toString().slice(-6)} is awaiting dispatch.`,
                    type: 'transaction',
                    data: { orderId: order._id, listingId: listing._id }
                });

                io.to(`order_${order._id}`).emit('order_created', {
                    orderId: order._id,
                    listingId: listing._id,
                    sellerId: listing.seller._id,
                    buyerId: buyer._id,
                    price: total,
                    timestamp: new Date()
                });

                res.json({
                    success: true,
                    message: 'Purchase successful. Escrow locked.',
                    data: {
                        orderId: order._id,
                        status: order.status,
                        total,
                        price,
                        fee
                    }
                });

            } catch (error) {
                await session.abortTransaction();
                throw error;
            } finally {
                session.endSession();
            }

        } catch (error) {
            console.error('Buy error:', error);
            res.status(500).json({ 
                success: false, 
                message: 'Purchase failed',
                code: 'PURCHASE_FAILED'
            });
        }
    }
);

