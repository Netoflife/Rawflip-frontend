// Send message
app.post('/api/messages', 
    authenticate,
    upload.single('file'),
    (req, res, next) => {
        const rules = [];
        if (req.body.listingId) rules.push('listingId');
        if (req.body.type === 'offer') rules.push('offerPrice');
        req.validationRules = rules;
        next();
    },
    body('listingId').optional().isMongoId().withMessage('Invalid listing ID'),
    body('type').optional().isIn(['text', 'offer', 'video', 'image']).withMessage('Invalid message type'),
    body('offerPrice').optional().custom((value, { req }) => {
        if (req.body.type === 'offer') {
            if (!value || value <= 0) {
                throw new Error('Offer price is required and must be greater than 0');
            }
        }
        return true;
    }),
    validate,
    async (req, res) => {
        try {
            const { listingId, content, type = 'text', offerPrice } = req.body;
            
            if (!listingId && !req.file) {
                if (req.file) cleanupFile(req.file.path);
                return res.status(400).json({ 
                    success: false, 
                    message: 'Listing ID or recipient required',
                    code: 'MISSING_FIELDS'
                });
            }
            
            let listing = null;
            let listingTitle = 'Unknown Listing';
            let listingImage = null;
            let recipient = null;

            if (listingId) {
                listing = await Listing.findById(listingId);
                if (listing) {
                    listingTitle = listing.title;
                    listingImage = listing.images?.[0] || null;
                    recipient = listing.seller;
                } else {
                    if (req.file) cleanupFile(req.file.path);
                    return res.status(404).json({ 
                        success: false, 
                        message: 'Listing not found',
                        code: 'LISTING_NOT_FOUND'
                    });
                }
            }

            if (!recipient) {
                const existingMsg = await Message.findOne({
                    participants: { $in: [req.user._id] }
                }).sort({ createdAt: -1 });
                
                if (existingMsg) {
                    recipient = existingMsg.from.toString() === req.user._id.toString() 
                        ? existingMsg.to 
                        : existingMsg.from;
                }
            }

            if (!recipient) {
                if (req.file) cleanupFile(req.file.path);
                return res.status(400).json({ 
                    success: false, 
                    message: 'Cannot determine recipient',
                    code: 'RECIPIENT_UNKNOWN'
                });
            }

            const recipientUser = await User.findById(recipient);
            if (!recipientUser) {
                if (req.file) cleanupFile(req.file.path);
                return res.status(404).json({ 
                    success: false, 
                    message: 'Recipient not found',
                    code: 'RECIPIENT_NOT_FOUND'
                });
            }
            
            const participants = [req.user._id, recipient].sort();
            const conversationId = participants.join('_');

            const message = new Message({
                listingId: listingId || null,
                from: req.user._id,
                to: recipient,
                fromUsername: req.user.username,
                toUsername: recipientUser?.username || 'Unknown',
                listingTitle: listingTitle,
                listingImage: listingImage,
                content: content || (req.file ? 'Sent an attachment' : ''),
                type: req.file?.mimetype?.startsWith('video/') ? 'video' : (type || 'text'),
                fileUrl: req.file ? req.file.path : null,
                offerPrice: type === 'offer' && offerPrice ? parseFloat(offerPrice) : null,
                offerStatus: type === 'offer' && offerPrice ? 'pending' : null,
                expiresAt: type === 'offer' && offerPrice ? new Date(Date.now() + CONSTANTS.OFFER_EXPIRY_HOURS * 60 * 60 * 1000) : null,
                participants: participants,
                conversationId
            });

            await message.save();

            if (type === 'offer' && offerPrice && listing) {
                const offer = new Offer({
                    listingId,
                    buyerId: req.user._id,
                    sellerId: listing.seller,
                    originalPrice: listing.price,
                    acceptedPrice: parseFloat(offerPrice),
                    status: 'pending',
                    expiresAt: new Date(Date.now() + CONSTANTS.OFFER_EXPIRY_HOURS * 60 * 60 * 1000)
                });

                await offer.save();
                
                const offerNotification = new Notification({
                    userId: recipient,
                    type: 'offer',
                    message: `You have received a price offer of ₦${parseFloat(offerPrice).toFixed(2)} for "${listing.title}" from ${req.user.username}`,
                    data: { offerId: offer._id, listingId, price: offerPrice }
                });
                await offerNotification.save();
                
                io.to(`user_${recipient}`).emit('notification', {
                    userId: recipient.toString(),
                    message: `New offer received for "${listing.title}"`,
                    type: 'offer',
                    data: { offerId: offer._id, listingId }
                });
                
                await auditLog(req.user._id, 'offer_sent', 'Offer', offer._id, { 
                    listingId, 
                    price: offerPrice 
                }, req);

                await trackEvent(req.user._id, 'send_offer', 'offer', 'create', parseFloat(offerPrice), { 
                    listingId,
                    sellerId: listing.seller,
                    offerId: offer._id
                }, req);
            } else if (type === 'text' || type === 'video' || type === 'image') {
                const chatNotification = new Notification({
                    userId: recipient,
                    type: 'message',
                    message: `New message from ${req.user.username}${listing ? ` about "${listing.title}"` : ''}`,
                    data: { messageId: message._id, listingId }
                });
                await chatNotification.save();
                
                io.to(`user_${recipient}`).emit('notification', {
                    userId: recipient.toString(),
                    message: `New message from ${req.user.username}`,
                    type: 'message',
                    data: { messageId: message._id, listingId }
                });

                await trackEvent(req.user._id, 'send_message', 'message', 'send', null, { 
                    listingId,
                    recipientId: recipient,
                    messageId: message._id,
                    hasFile: !!req.file
                }, req);
            }

            io.to(`conversation_${conversationId}`).emit('message', {
                conversationId,
                listingId,
                listingTitle,
                from: req.user.username,
                to: recipient,
                content: content || 'Sent an attachment',
                type: message.type,
                timestamp: new Date()
            });

            res.json({
                success: true,
                message: type === 'offer' ? 'Offer sent successfully' : 'Message sent successfully',
                data: {
                    _id: message._id,
                    type: message.type,
                    offerStatus: message.offerStatus,
                    expiresAt: message.expiresAt
                }
            });

        } catch (error) {
            if (req.file) cleanupFile(req.file.path);
            console.error('Send message error:', error);
            res.status(500).json({ 
                success: false, 
                message: 'Failed to send message',
                code: 'MESSAGE_SEND_FAILED'
            });
        }
    }
);

