// Withdrawal request
app.post('/api/wallet/withdraw', 
    authenticate,
    (req, res, next) => {
        req.validationRules = ['amount', 'bank', 'acc', 'pin'];
        next();
    },
    body('amount').isFloat({ gt: 0 }).withMessage('Invalid amount'),
    body('bank').notEmpty().withMessage('Bank name required'),
    body('acc').notEmpty().withMessage('Account number required'),
    body('pin').isLength({ min: 4, max: 4 }).isNumeric().withMessage('PIN must be exactly 4 digits'),
    validate,
    async (req, res) => {
        try {
            const { amount, bank, acc, pin } = req.body;
            
            if (!amount || !bank || !acc || !pin) {
                return res.status(400).json({ 
                    success: false, 
                    message: 'All fields required',
                    code: 'MISSING_FIELDS'
                });
            }

            const user = await User.findById(req.user._id);

            const validPin = user.security_pin && 
                await bcrypt.compare(pin, user.security_pin);
            
            if (!validPin) {
                return res.status(400).json({ 
                    success: false, 
                    message: 'Invalid security PIN',
                    code: 'INVALID_PIN'
                });
            }

            const amountNum = parseFloat(amount);
            
            if (user.earningBalance < amountNum) {
                return res.status(400).json({ 
                    success: false, 
                    message: `Insufficient settled earnings. Need ₦${amountNum.toFixed(2)}, have ₦${user.earningBalance.toFixed(2)}`,
                    required: amountNum,
                    available: user.earningBalance,
                    code: 'INSUFFICIENT_BALANCE'
                });
            }

            if (amountNum < CONSTANTS.MIN_WITHDRAWAL) {
                return res.status(400).json({ 
                    success: false, 
                    message: `Minimum withdrawal is ₦${CONSTANTS.MIN_WITHDRAWAL}`,
                    minAmount: CONSTANTS.MIN_WITHDRAWAL,
                    code: 'MINIMUM_NOT_MET'
                });
            }

            if (user.kyc_status !== 'approved') {
                return res.status(400).json({ 
                    success: false, 
                    message: 'KYC verification required for withdrawals',
                    code: 'KYC_REQUIRED'
                });
            }

            const fee = Math.ceil(amountNum / 5000) * CONSTANTS.WITHDRAWAL_FEE_PER_5000;
            const netAmount = amountNum - fee;

            const withdrawal = new Withdrawal({
                userId: user._id,
                amount: amountNum,
                bank,
                accountNumber: acc,
                fee,
                netAmount,
                status: 'pending'
            });

            await withdrawal.save();

            user.earningBalance -= amountNum;
            await user.save();

            const transaction = new Transaction({
                userId: user._id,
                type: 'withdrawal',
                amount: amountNum,
                description: `Withdrawal request to ${bank}`,
                status: 'pending',
                reference: generateReference(),
                metadata: { withdrawalId: withdrawal._id, fee, netAmount }
            });

            await transaction.save();

            await auditLog(user._id, 'withdrawal_request', 'Withdrawal', withdrawal._id, { 
                amount: amountNum, 
                fee, 
                netAmount 
            }, req);

            await trackEvent(user._id, 'withdrawal_request', 'wallet', 'withdrawal', amountNum, { 
                withdrawalId: withdrawal._id,
                netAmount
            }, req);

            res.json({
                success: true,
                message: 'Withdrawal request submitted',
                data: { withdrawalId: withdrawal._id, netAmount, fee }
            });

        } catch (error) {
            console.error('Withdrawal error:', error);
            res.status(500).json({ 
                success: false, 
                message: 'Failed to submit withdrawal request',
                code: 'WITHDRAWAL_FAILED'
            });
        }
    }
);

