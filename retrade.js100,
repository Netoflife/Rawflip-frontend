app.post('/api/messages/offer/:action', 
    authenticate,
    (req, res, next) => {
        req.validationRules = ['action', 'offerId'];
        next();
    },
    param('action').isIn(['accepted', 'declined']).withMessage('Invalid action'),
    body('offerId').isMongoId().withMessage('Invalid offer ID'),
    validate,
    async (req, res) => {
        try {
            const { action } = req.params;
            const { offerId } = req.body;

            const offer = await Offer.findById(offerId).populate('listingId').populate('buyerId').populate('sellerId');
            if (!offer) {
                return res.status(404).json({ 
                    success: false, 
                    message: 'Offer not found',
                    code: 'OFFER_NOT_FOUND'
                });
            }

            if (offer.sellerId._id.toString() !== req.user._id.toString()) {
                return res.status(403).json({ 
                    success: false, 
                    message: 'Not authorized',
                    code: 'UNAUTHORIZED'
                });
            }

            if (offer.status !== 'pending') {
                return res.status(400).json({ 
                    success: false, 
                    message: 'This offer is no longer pending',
                    code: 'OFFER_NOT_PENDING'
                });
            }

            if (offer.expiresAt < new Date()) {
                offer.status = 'expired';
                await offer.save();
                return res.status(400).json({ 
                    success: false, 
                    message: 'Offer has expired',
                    code: 'OFFER_EXPIRED'
                });
            }

            offer.status = action;
            await offer.save();

            if (action === 'accepted') {
                const notification = new Notification({
                    userId: offer.buyerId._id,
                    type: 'offer',
                    message: `Your offer of ₦${offer.acceptedPrice.toFixed(2)} for "${offer.listingId.title}" has been accepted! You can now purchase at the agreed price.`,
                    data: { offerId: offer._id, listingId: offer.listingId._id }
                });
                await notification.save();
                
                io.to(`user_${offer.buyerId._id}`).emit('notification', {
                    userId: offer.buyerId._id.toString(),
                    message: `Your offer for "${offer.listingId.title}" was accepted`,
                    type: 'offer',
                    data: { offerId: offer._id, listingId: offer.listingId._id }
                });
                
                await auditLog(req.user._id, 'offer_accepted', 'Offer', offer._id, null, req);
                await trackEvent(req.user._id, 'offer_accepted', 'offer', action, offer.acceptedPrice, { 
                    offerId: offer._id,
                    buyerId: offer.buyerId._id,
                    listingId: offer.listingId._id
                }, req);
            } else {
                const notification = new Notification({
                    userId: offer.buyerId._id,
                    type: 'offer',
                    message: `Your offer of ₦${offer.acceptedPrice.toFixed(2)} for "${offer.listingId.title}" has been declined.`,
                    data: { offerId: offer._id, listingId: offer.listingId._id }
                });
                await notification.save();
                
                io.to(`user_${offer.buyerId._id}`).emit('notification', {
                    userId: offer.buyerId._id.toString(),
                    message: `Your offer for "${offer.listingId.title}" was declined`,
                    type: 'offer',
                    data: { offerId: offer._id, listingId: offer.listingId._id }
                });
                
                await auditLog(req.user._id, 'offer_declined', 'Offer', offer._id, null, req);
                await trackEvent(req.user._id, 'offer_declined', 'offer', action, offer.acceptedPrice, { 
                    offerId: offer._id,
                    buyerId: offer.buyerId._id,
                    listingId: offer.listingId._id
                }, req);
            }

            res.json({
                success: true,
                message: `Offer ${action} successfully`,
                data: { offerStatus: action }
            });

        } catch (error) {
            console.error('Offer action error:', error);
            res.status(500).json({ 
