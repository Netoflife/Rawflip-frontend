                io.to(`user_${seller._id}`).emit('notification', {
                    userId: seller._id.toString(),
                    message: `Funds released for "${order.title}". ₦${sellerPayout.toFixed(2)} added to your earnings balance.`,
                    type: 'transaction',
                    data: { orderId: order._id }
                });

