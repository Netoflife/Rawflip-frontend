    validate,
    async (req, res) => {
        try {
            const { rating, comment } = req.body;
            const order = await Order.findById(req.params.id).populate('buyerId').populate('sellerId');

            if (!order) {
                return res.status(404).json({ 
                    success: false, 
                    message: 'Order not found',
                    code: 'ORDER_NOT_FOUND'
                });
            }

            if (order.buyerId._id.toString() !== req.user._id.toString()) {
                return res.status(403).json({ 
                    success: false, 
                    message: 'Not authorized',
                    code: 'UNAUTHORIZED'
                });
            }

            if (order.status !== 'delivered') {
                return res.status(400).json({ 
                    success: false, 
                    message: 'Order must be delivered first',
                    code: 'INVALID_ORDER_STATUS'
                });
            }

            const session = await mongoose.startSession();
            session.startTransaction();

            try {
                order.rating = rating;
                order.comment = comment;
                order.status = 'completed';
                order.updatedAt = new Date();
                await order.save({ session });

                const seller = await User.findById(order.sellerId._id).session(session);
                const sellerPayout = order.price - order.fee;
                seller.earningBalance += sellerPayout;
                
                const currentScore = seller.trustScore || 5.0;
                const newScore = (currentScore + rating) / 2;
                seller.trustScore = Math.min(10.0, Math.max(0, newScore));
                await seller.save({ session });

                const buyer = await User.findById(order.buyerId._id).session(session);
                buyer.locked -= order.total;
                await buyer.save({ session });

                if (order.listingId) {
                    await Listing.findByIdAndUpdate(order.listingId, { status: 'completed' }).session(session);
                }

                const buyerTransaction = new Transaction({
                    userId: buyer._id,
